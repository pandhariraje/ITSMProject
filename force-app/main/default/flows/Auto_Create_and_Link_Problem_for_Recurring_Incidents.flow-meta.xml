<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>Problem_Already_Exists</name>
        <label>Problem Already Exists?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Problem_Found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Existing_Problem.Id</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>create_Related_pro_and_Inci</targetReference>
            </connector>
            <label>Problem Found</label>
        </rules>
        <rules>
            <name>Problem_Not_Found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Existing_Problem.Id</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Create_Problem</targetReference>
            </connector>
            <label>Problem Not Found</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <interviewLabel>Auto Create and Link Problem for Recurring Incidents {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Auto Create and Link Problem for Recurring Incidents</label>
    <processMetadataValues>
