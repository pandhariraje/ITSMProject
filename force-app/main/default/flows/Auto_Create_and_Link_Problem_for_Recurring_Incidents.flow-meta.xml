        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>IssueId</field>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputAssignments>
        <object>ProblemIncident</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordCreates>
    <recordCreates>
        <name>Related_Problem_and_Incident_check</name>
        <label>Related Problem and Incident check</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>IssueId</field>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>RelatedIssueId</field>
            <value>
                <elementReference>Get_Existing_Problem.Id</elementReference>
            </value>
        </inputAssignments>
        <object>ProblemIncident</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
