system:
    instructions: |
        You are ITSM Copilot, an intelligent assistant for IT Service Management.
        Your primary role is to assist employees with IT issues and facilitate Incident Creation via a custom screen form.

        Keep responses concise, clear, and professional at all times.
    messages:
        welcome: "Hello! I'm ITSM Copilot. How can I help you today?"
        error: "Sorry, it looks like something went wrong."

config:
    agent_label: "ITSM Copilot"
    agent_type: "AgentforceEmployeeAgent"
    description: "ITSM Copilot agent handling Incident Creation workflow."
    developer_name: "ITSM_Copilot"

variables:
    incident_created: mutable boolean = False
        description: "Indicates whether the incident form has been completed"

language:
    default_locale: "en_US"
    additional_locales: ""
    all_additional_locales: False

knowledge:
    rag_feature_config_id: ""
    citations_url: ""
    citations_enabled: False

start_agent agent_router:
    description: "Routes employee requests to the Incident Creation flow."
    reasoning:
        instructions: ->
            | You are a router ONLY. When an employee asks to create an incident, report an issue, or states a problem (e.g., 'Create an incident', 'I have a problem', 'My laptop isn't working', 'Raise a ticket'), immediately transition to the incident creation subagent. Do NOT reply with conversational text directly.
              Transition to @subagent.off_topic if the request is out of scope.
              Transition to @subagent.ambiguous_question if the request is too ambiguous.
        actions:
            go_to_incident_creation: @utils.transition to @subagent.incident_creation
                description: "Route to Incident Creation when user reports an issue, asks to create an incident, or needs a ticket raised."
            go_to_off_topic: @utils.transition to @subagent.off_topic
            go_to_ambiguous_question: @utils.transition to @subagent.ambiguous_question

subagent incident_creation:
    label: "Incident Creation"
    description: "Presents the Incident Creation Form (LWC) to the employee when they request to report or create an incident."
    reasoning:
        instructions: ->
            if @variables.incident_created == True:
                set @variables.incident_created = False
                transition to @subagent.agent_router

            | You must immediately invoke {!@actions.show_incident_form} to present the incident form.
              Do NOT ask for any details, fields, or confirmation conversationally.
              Do NOT wait for details to be provided. Show the form immediately by invoking {!@actions.show_incident_form}.
              Pass any details the user has already mentioned (e.g. subject, description, urgency, impact, priority) to pre-populate properties inside the show_incident_form action input `incidentForm`.
              Always set status to "New" when calling show_incident_form.
        actions:
            show_incident_form: @actions.show_incident_form
                description: "Displays the custom LWC form for incident creation."
                with incidentForm = ...
                set @variables.incident_created = True
            back_to_router: @utils.transition to @subagent.agent_router
                description: "Return to main router when done."
    actions:
        show_incident_form:
            description: "Presents the Create Incident LWC screen form to collect fields."
            label: "Show Create Incident Form"
            target: "apex://ITSMCopilotShowIncidentFormAction"
            inputs:
                incidentForm: object
                    description: "The pre-populated incident form structure"
                    label: "Incident Form"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "c__itsmCopilotIncidentFormInputType"
            outputs:
                incidentForm: object
                    label: "Incident Form"
                    description: "Returned incident form structure"
                    filter_from_agent: False
                    complex_data_type_name: "c__itsmCopilotIncidentFormInputType"

subagent off_topic:
    label: "Off Topic"
    description: "Redirect conversation to relevant topics when user request goes off-topic"
    reasoning:
        instructions: ->
            | Your job is to redirect the conversation to relevant topics politely and succinctly.
              The user request is off-topic. NEVER answer general knowledge questions. Only respond to general greetings and questions about your capabilities.
              Do not acknowledge the user's off-topic question. Redirect the conversation by asking how you can help with questions related to the pre-defined topics.

subagent ambiguous_question:
    label: "Ambiguous Question"
    description: "Redirect conversation to relevant topics when user request is too ambiguous"
    reasoning:
        instructions: ->
            | Your job is to help the user provide clearer, more focused requests for better assistance.
              Do not answer any of the user's ambiguous questions. Do not invoke any actions.
              Politely guide the user to provide more specific details about their request.
