            <language xsi:nil="true"/>
            <masterLabel>Instruction16</masterLabel>
            <sortOrder>15</sortOrder>
        </genAiPluginInstructions>
        <genAiPluginInstructions>
            <description>If the user is not happy with the suggestions or rejects the suggested catalog item, strictly ask if incident needs to be created. If the user confirms, then only run the employee incident creation action.</description>
            <developerName>Instruction17</developerName>
            <language xsi:nil="true"/>
            <masterLabel>Instruction17</masterLabel>
            <sortOrder>16</sortOrder>
        </genAiPluginInstructions>
        <genAiPluginInstructions>
            <description>If the user decides to abort the process while providing attributes because user feels suggested catalog item is incorrect then strictly ask if incident needs to be created. If the user confirms, then only run the employee incident creation action.</description>
