<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Resolution_Summary_cannot_be_blank</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
ISPICKVAL(Status , &quot;Resolved&quot;),
ISBLANK( ResolutionSummary )
)</errorConditionFormula>
    <errorDisplayField>ResolutionSummary</errorDisplayField>
    <errorMessage>Resolution Summary should not be blank</errorMessage>
</ValidationRule>
